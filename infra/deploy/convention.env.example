# Production environment for the Convention Platform API.
# Install to /etc/convention.env (chmod 600), referenced by PM2 / the systemd
# units. Third-party API keys (Stripe/SendGrid/Cloudflare/Maps/reCAPTCHA) are
# NOT here — enter them in the admin Settings panel (encrypted at rest).

NODE_ENV=production
PORT=4000

# Public origins (your real domain)
CLIENT_ORIGIN=https://YOUR_DOMAIN
PUBLIC_URL=https://YOUR_DOMAIN

# Postgres 18 (the local role/db created in DEPLOY.md, or a managed URL)
DATABASE_URL=postgresql://convention:STRONG_DB_PASSWORD@localhost:5432/convention

# Generate both:  openssl rand -hex 48   and   openssl rand -hex 32
JWT_SECRET=REPLACE_WITH_openssl_rand_hex_48
SETTINGS_MASTER_KEY=REPLACE_WITH_openssl_rand_hex_32

# BotBlock tunables (defaults are sensible)
BOTBLOCK_ENABLED=true
BOTBLOCK_PENDING_FILE=/tmp/botblock-pending
BOTBLOCK_THRESHOLD=6
BOTBLOCK_WINDOW_MINUTES=10
BOTBLOCK_TTL_HOURS=24
